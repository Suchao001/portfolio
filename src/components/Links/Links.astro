---
import { Icon } from "astro-icon/components";
import { PERSONAL_INFO } from "../../data/personal";

interface Props {
    class?: string;
}

const { class: className } = Astro.props;
---

<div class:list={["flex items-center gap-6 mb-6", className]}>
    {
        PERSONAL_INFO.socialLinks.map((link: { href: string; label: string; icon: string }) => (
            <a
                href={link.href}
                target="_blank"
                rel="noopener noreferrer"
                class="text-primary hover:text-purple-400 transition-all duration-300 hover:scale-110"
                aria-label={link.label}
            >
                <Icon name={link.icon} class="size-6 md:size-8" />
            </a>
        ))
    }
</div>

<style>
    .text-primary {
        color: #7836cf;
    }
</style>
