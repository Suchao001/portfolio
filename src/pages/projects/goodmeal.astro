---
import Layout from "../../layouts/Layout.astro";
import Badge from "../../components/UI/Badge.astro";
import { Icon } from "astro-icon/components";
import { TAGS } from "../../data/projects";

const projectTags = [
    TAGS.NEXT,
    TAGS.REACT_NATIVE,
    TAGS.EXPRESS,
    TAGS.TYPESCRIPT,
    TAGS.TAILWIND,
    TAGS.MYSQL,
];
---

<Layout>
    <main class="relative z-10 w-full pt-32 pb-24 px-6 max-w-7xl mx-auto min-h-screen">
        <a href="/#projects" class="text-gray-300 hover:text-white flex items-center gap-2 mb-10 w-fit px-4 py-2 rounded-full border border-white/5 bg-white/5 backdrop-blur-sm transition-all hover:bg-white/10 hover:border-white/20">
            <Icon name="lucide:arrow-left" class="size-4" />
            Back to Projects
        </a>

        <div class="mb-16">
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold bg-clip-text text-transparent bg-linear-to-r from-purple-400 to-cyan-400 mb-6 tracking-tight">
                Goodmeal | AI FoodMenu<br/>FoodPlan and Report
            </h1>
            <p class="text-lg md:text-xl text-gray-300 leading-relaxed max-w-4xl mb-8 font-light">
                พัฒนาระบบสร้างแผนมื้ออาหารและแนะนำอาหารส่วนบุคคลสำหรับผู้ใช้ พัฒนาฟังก์ชันให้ผู้ใช้สามารถเพิ่มมื้ออาหารและสร้างแผนการกินที่ปรับแต่งได้ในหลายรูปแบบ สร้างระบบบันทึกมื้ออาหารและฟีเจอร์รายงานผลเพื่อช่วยให้เข้าใจพฤติกรรมการกินของตนเอง
            </p>

            <ul class="flex flex-wrap gap-3">
                {
                    projectTags.map((tag) => (
                        <li>
                            <Badge
                                class:list={[
                                    "flex items-center gap-x-2 text-sm py-2 px-4 border-white/10 shadow-lg",
                                    tag.class,
                                ]}
                            >
                                <Icon name={tag.icon} class="size-4" />
                                {tag.name}
                            </Badge>
                        </li>
                    ))
                }
            </ul>
        </div>

        <div class="space-y-24">
            <!-- Admin Section -->
            <section id="admin-section" class="scroll-mt-24">
                <div class="flex items-center gap-4 mb-10 border-b border-white/10 pb-4">
                    <div class="p-3 rounded-xl bg-purple-500/20 text-purple-400 border border-purple-500/30">
                        <Icon name="lucide:monitor" class="size-6" />
                    </div>
                    <h2 class="text-3xl font-bold text-white">Admin Dashboard</h2>
                </div>
                
                <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                    <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gray-900/50 shadow-2xl transition duration-500 hover:border-purple-500/50 hover:shadow-[0_0_30px_rgba(168,85,247,0.2)]">
                        <div class="absolute inset-0 bg-linear-to-t from-gray-900/60 to-transparent z-10 pointer-events-none"></div>
                        <img src="/projects/Goodmeal/admin1.png" alt="Admin Dashboard Step 1" class="w-full h-full object-cover object-top aspect-4/3 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    </div>
                    <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gray-900/50 shadow-2xl transition duration-500 hover:border-purple-500/50 hover:shadow-[0_0_30px_rgba(168,85,247,0.2)] lg:translate-y-6">
                        <div class="absolute inset-0 bg-linear-to-t from-gray-900/60 to-transparent z-10 pointer-events-none"></div>
                        <img src="/projects/Goodmeal/admin2.png" alt="Admin Dashboard Step 2" class="w-full h-full object-cover object-top aspect-4/3 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    </div>
                    <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gray-900/50 shadow-2xl transition duration-500 hover:border-purple-500/50 hover:shadow-[0_0_30px_rgba(168,85,247,0.2)] lg:translate-y-12">
                        <div class="absolute inset-0 bg-linear-to-t from-gray-900/60 to-transparent z-10 pointer-events-none"></div>
                        <img src="/projects/Goodmeal/admin3.png" alt="Admin Dashboard Step 3" class="w-full h-full object-cover object-top aspect-4/3 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    </div>
                </div>
            </section>

            <!-- User Mobile Section -->
            <section id="user-section" class="scroll-mt-24 pt-12">
                <div class="flex items-center gap-4 mb-10 border-b border-white/10 pb-4">
                    <div class="p-3 rounded-xl bg-cyan-500/20 text-cyan-400 border border-cyan-500/30">
                        <Icon name="lucide:smartphone" class="size-6" />
                    </div>
                    <h2 class="text-3xl font-bold text-white">User Mobile App</h2>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-3 gap-x-8 gap-y-16 place-items-center">
                    <div class="group relative bg-black rounded-[2.5rem] p-2 border border-gray-800 shadow-2xl transition-all duration-500 hover:border-cyan-500/50 hover:shadow-[0_0_40px_rgba(34,211,238,0.2)] w-full max-w-[320px]">
                        <div class="absolute top-0 inset-x-0 h-4 bg-gray-800/50 rounded-t-3xl blur-md"></div>
                        <div class="overflow-hidden rounded-4xl bg-gray-900 border border-gray-800/50 relative">
                             <div class="absolute top-0 inset-x-0 flex justify-center z-20">
                                <div class="w-32 h-6 bg-black rounded-b-2xl"></div>
                            </div>
                            <img src="/projects/Goodmeal/user1.png" alt="User App Step 1" class="w-full object-cover group-hover:scale-[1.02] transition-transform duration-700 ease-out" loading="lazy" />
                        </div>
                    </div>
                    
                    <div class="group relative bg-black rounded-[2.5rem] p-2 border border-gray-800 shadow-2xl transition-all duration-500 hover:border-cyan-500/50 hover:shadow-[0_0_40px_rgba(34,211,238,0.2)] w-full max-w-[320px] md:translate-y-8">
                        <div class="absolute top-0 inset-x-0 h-4 bg-gray-800/50 rounded-t-3xl blur-md"></div>
                        <div class="overflow-hidden rounded-4xl bg-gray-900 border border-gray-800/50 relative">
                             <div class="absolute top-0 inset-x-0 flex justify-center z-20">
                                <div class="w-32 h-6 bg-black rounded-b-2xl"></div>
                            </div>
                            <img src="/projects/Goodmeal/user2.png" alt="User App Step 2" class="w-full object-cover group-hover:scale-[1.02] transition-transform duration-700 ease-out" loading="lazy" />
                        </div>
                    </div>

                    <div class="group relative bg-black rounded-[2.5rem] p-2 border border-gray-800 shadow-2xl transition-all duration-500 hover:border-cyan-500/50 hover:shadow-[0_0_40px_rgba(34,211,238,0.2)] w-full max-w-[320px] md:translate-y-16">
                        <div class="absolute top-0 inset-x-0 h-4 bg-gray-800/50 rounded-t-3xl blur-md"></div>
                        <div class="overflow-hidden rounded-4xl bg-gray-900 border border-gray-800/50 relative">
                             <div class="absolute top-0 inset-x-0 flex justify-center z-20">
                                <div class="w-32 h-6 bg-black rounded-b-2xl"></div>
                            </div>
                            <img src="/projects/Goodmeal/user3.png" alt="User App Step 3" class="w-full object-cover group-hover:scale-[1.02] transition-transform duration-700 ease-out" loading="lazy" />
                        </div>
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>
