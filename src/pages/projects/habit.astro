---
import Layout from "../../layouts/Layout.astro";
import Badge from "../../components/UI/Badge.astro";
import { Icon } from "astro-icon/components";
import { TAGS } from "../../data/projects";

const projectTags = [
    TAGS.REACT,
    TAGS.EXPRESS,
    TAGS.JAVASCRIPT,
    TAGS.HTML,
    TAGS.CSS,
    TAGS.MYSQL,
];
---

<Layout>
    <main class="relative z-10 w-full pt-32 pb-24 px-6 max-w-7xl mx-auto min-h-screen">
        <a href="/#projects" class="text-gray-300 hover:text-white flex items-center gap-2 mb-10 w-fit px-4 py-2 rounded-full border border-white/5 bg-white/5 backdrop-blur-sm transition-all hover:bg-white/10 hover:border-white/20">
            <Icon name="lucide:arrow-left" class="size-4" />
            Back to Projects
        </a>

        <div class="mb-16">
            <h1 class="text-4xl md:text-5xl lg:text-7xl font-extrabold bg-clip-text text-transparent bg-linear-to-r from-orange-400 to-yellow-400 mb-6 tracking-tight">
                Habit Task & Planner
            </h1>
            <p class="text-lg md:text-xl text-gray-300 leading-relaxed max-w-4xl mb-8 font-light">
                แอปพลิเคชันจัดการพฤติกรรมและเป้าหมายส่วนบุคคล พัฒนาด้วย ReactJs และ ExpressJs เพื่อช่วยผู้ใช้สร้างพฤติกรรมเชิงบวก มีฟีเจอร์แสดงความคืบหน้า ติดตามประวัติงานที่ทำสำเร็จ ตั้งเป้าหมายที่ปรับแต่งได้ และโปรไฟล์ผู้ใช้ หน้าปฏิทินแสดงกิจกรรมที่ต้องทำ พร้อมระบบค้นหาที่เข้าถึงได้รวดเร็ว รวมถึงมีระบบยืนยันตัวตนและ Admin Dashboard สำหรับจัดการผู้ใช้และตั้งค่าระบบ
            </p>

            <ul class="flex flex-wrap gap-3 mb-8">
                {
                    projectTags.map((tag) => (
                        <li>
                            <Badge
                                class:list={[
                                    "flex items-center gap-x-2 text-sm py-2 px-4 border-white/10 shadow-lg",
                                    tag.class,
                                ]}
                            >
                                <Icon name={tag.icon} class="size-4" />
                                {tag.name}
                            </Badge>
                        </li>
                    ))
                }
            </ul>
        </div>

        <div class="space-y-24">
            <section id="system-preview" class="scroll-mt-24">
                <div class="flex items-center gap-4 mb-10 border-b border-white/10 pb-4">
                    <div class="p-3 rounded-xl bg-orange-500/20 text-orange-400 border border-orange-500/30">
                        <Icon name="lucide:layout-dashboard" class="size-6" />
                    </div>
                    <h2 class="text-3xl font-bold text-white">System Preview</h2>
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-8 pb-12">
                    <!-- Gallery of images -->
                    <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gray-900/50 shadow-2xl transition duration-500 hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(249,115,22,0.2)]">
                        <div class="absolute inset-0 bg-linear-to-t from-gray-900/60 to-transparent z-10 pointer-events-none"></div>
                        <img src="/projects/habit/image.png" alt="Habit Planner Preview 1" class="w-full h-full object-cover object-top aspect-4/3 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    </div>
                    <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gray-900/50 shadow-2xl transition duration-500 hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(249,115,22,0.2)] md:translate-y-6">
                        <div class="absolute inset-0 bg-linear-to-t from-gray-900/60 to-transparent z-10 pointer-events-none"></div>
                        <img src="/projects/habit/image (1).png" alt="Habit Planner Preview 2" class="w-full h-full object-cover object-top aspect-4/3 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    </div>
                    <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gray-900/50 shadow-2xl transition duration-500 hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(249,115,22,0.2)]">
                        <div class="absolute inset-0 bg-linear-to-t from-gray-900/60 to-transparent z-10 pointer-events-none"></div>
                        <img src="/projects/habit/image (2).png" alt="Habit Planner Preview 3" class="w-full h-full object-cover object-top aspect-4/3 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    </div>
                    <div class="group relative overflow-hidden rounded-2xl border border-white/10 bg-gray-900/50 shadow-2xl transition duration-500 hover:border-orange-500/50 hover:shadow-[0_0_30px_rgba(249,115,22,0.2)] md:translate-y-6">
                        <div class="absolute inset-0 bg-linear-to-t from-gray-900/60 to-transparent z-10 pointer-events-none"></div>
                        <img src="/projects/habit/image (3).png" alt="Habit Planner Preview 4" class="w-full h-full object-cover object-top aspect-4/3 group-hover:scale-105 transition-transform duration-700 ease-out" loading="lazy" />
                    </div>
                </div>
            </section>
        </div>
    </main>
</Layout>
